<div class="col-md-3 mx-auto">
  <h1>ユーザー編集</h1>
  <%= form_with(model: @user) do |form| %>
    <% if @user.errors.any? %>
      <div class="alert alert-danger">
        <% @user.errors.each do |error| %>
          <%= error.message %>
        <% end %>
      </div>
    <% end %>
    <%= form.text_field :name, placeholder: '名前', class: 'form-control', required: true %>
    <%= form.submit '適用', class: 'btn btn-primary w-100 mt-2' %>
  <% end %>
</div>
